# ─── Veritabanı ───────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/turkiyedesatilik"

# ─── Uygulama ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://turkiyedesatilik.com"
NEXT_PUBLIC_SITE_NAME="Türkiye'de Satılık"

# ─── Auth (NextAuth.js veya benzeri) ──────────────────────────────────
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://turkiyedesatilik.com"

# ─── Dosya Yükleme (S3 uyumlu — ör. AWS S3 / Cloudflare R2) ──────────
S3_BUCKET_NAME="turkiyedesatilik-media"
S3_REGION="eu-central-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""                        # Cloudflare R2 için gerekli

# ─── Harita ───────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""    # veya Mapbox token

# ─── Redis (isteğe bağlı cache / session) ─────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── E-posta ──────────────────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="info@turkiyedesatilik.com"
SMTP_PASS=""
SMTP_FROM="Türkiye'de Satılık <info@turkiyedesatilik.com>"

# ─── Analytics ────────────────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=""
NEXT_PUBLIC_GA_ID=""
